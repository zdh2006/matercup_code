# 第七部分：分层分配求解器（问题二/四）
# ============================================================

class HierarchicalPCISolver:
    """
    空间层次分解与主从伴随串行优化的PCI分层分配
    第一层：最小化冲突MR
    第二层：最小化混淆MR（冲突MR为约束）
    第三层：最小化模3干扰MR（冲突+混淆MR为约束）
    """
    
    def __init__(self, preprocessor, use_tabu=False, **kwargs):
        self.preprocessor = preprocessor
        self.use_tabu = use_tabu
        self.kwargs = kwargs
        self.obj_func = ObjectiveFunction(
            preprocessor.conflict_matrix,
            preprocessor.confusion_matrix,
            preprocessor.interference_matrix
        )
    
    def solve(self):
        """分层求解"""
        print("=" * 60)
        print("第一层：最小化冲突MR")
        print("=" * 60)
        
        OptimizerClass = TabuMasterSlaveOptimizer if self.use_tabu else MasterSlaveOptimizer
        
        # 第一层：以冲突MR最小为目标
        optimizer1 = OptimizerClass(self.preprocessor, self.obj_func, **self.kwargs)
        optimizer1.setup(matrix_type='conflict')
        pci_layer1, cost1, hist1 = optimizer1.optimize(
            eval_func=self.obj_func.compute_conflict_mr
        )
        
        conflict_mr_1 = self.obj_func.compute_conflict_mr(pci_layer1)
        print(f"第一层完成: 冲突MR = {conflict_mr_1}")
        
        print("\n" + "=" * 60)
        print("第二层：最小化混淆MR（保持冲突MR不增加）")
        print("=" * 60)
        
        # 第二层：以混淆MR最小为目标，约束冲突MR <= 第一层结果
        optimizer2 = OptimizerClass(self.preprocessor, self.obj_func, **self.kwargs)
        optimizer2.setup(matrix_type='confusion')
        
        def eval_layer2(pci):
            conf_mr = self.obj_func.compute_conflict_mr(pci)
            if conf_mr > conflict_mr_1:
                return float('inf')
            return self.obj_func.compute_confusion_mr(pci)
        
        # 用第一层的结果作为初始解的基础
        pci_layer2, cost2, hist2 = optimizer2.optimize(eval_func=eval_layer2)
        
        # 如果第二层没有改善，保留第一层结果
        if self.obj_func.compute_conflict_mr(pci_layer2) > conflict_mr_1:
            pci_layer2 = pci_layer1.copy()
        
        confusion_mr_2 = self.obj_func.compute_confusion_mr(pci_layer2)
        print(f"第二层完成: 混淆MR = {confusion_mr_2}")
        
        print("\n" + "=" * 60)
        print("第三层：最小化模3干扰MR（保持冲突和混淆MR不增加）")
        print("=" * 60)
        
        # 第三层：以模3干扰MR最小为目标
        optimizer3 = OptimizerClass(self.preprocessor, self.obj_func, **self.kwargs)
        optimizer3.setup(matrix_type='interference')
        
        def eval_layer3(pci):
            conf_mr = self.obj_func.compute_conflict_mr(pci)
            confn_mr = self.obj_func.compute_confusion_mr(pci)
            if conf_mr > conflict_mr_1 or confn_mr > confusion_mr_2:
                return float('inf')
            return self.obj_func.compute_interference_mr(pci)
        
        pci_layer3, cost3, hist3 = optimizer3.optimize(eval_func=eval_layer3)
        
        if (self.obj_func.compute_conflict_mr(pci_layer3) > conflict_mr_1 or
            self.obj_func.compute_confusion_mr(pci_layer3) > confusion_mr_2):
            pci_layer3 = pci_layer2.copy()
        
        # 最终结果
        final_conflict = self.obj_func.compute_conflict_mr(pci_layer3)
        final_confusion = self.obj_func.compute_confusion_mr(pci_layer3)
        final_interference = self.obj_func.compute_interference_mr(pci_layer3)
        
        print(f"\n最终结果: 冲突MR={final_conflict}, "
              f"混淆MR={final_confusion}, 模3干扰MR={final_interference}")
        
        return pci_layer3, {
            'conflict_mr': final_conflict,
            'confusion_mr': final_confusion,
            'interference_mr': final_interference,
            'history': [hist1, hist2, hist3]
        }

