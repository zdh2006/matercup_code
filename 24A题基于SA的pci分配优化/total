# 第五部分：主从伴随优化算法（问题一/二）
# ============================================================

class MasterSlaveOptimizer:
    """
    基于空间分解与主从伴随优化的PCI综合分配
    以模拟退火为框架
    """
    
    def __init__(self, preprocessor, objective_func, num_pci=1008,
                 T0=1000, T_min=1, alpha=0.95, max_iter=500,
                 cum_threshold=20, con_threshold=5, omega=0.8):
        self.preprocessor = preprocessor
        self.obj_func = objective_func
        self.num_pci = num_pci
        self.n = preprocessor.num_cells
        
        # SA参数
        self.T0 = T0
        self.T_min = T_min
        self.alpha = alpha
        self.max_iter = max_iter
        
        # 扰动与终止参数
        self.cum_threshold = cum_threshold  # 触发扰动的阈值
        self.con_threshold = con_threshold  # 终止条件：扰动次数
        self.omega_weight = omega  # 邻域选择惯性权重
        
        # 空间分解结果
        self.primary_indices = []
        self.secondary_indices = []
        
        # 软着色器
        self.coloring = None
        
        # 邻域选择概率
        self.p_k = [0.5, 0.5]  # [解变换, 随机变异]
        self.s_k = [1, 1]  # 成功次数
        self.st_k = [1, 1]  # 选择次数
    
    def setup(self, matrix_type='comprehensive', decompose_threshold=0.5):
        """初始化：空间分解 + 软着色器"""
        # 计算冲突度
        conflict_degree = self.preprocessor.compute_region_conflict_degree(matrix_type)
        
        # 空间分解
        decomposer = SpaceDecomposer(threshold=decompose_threshold)
        self.primary_indices, self.secondary_indices = decomposer.decompose(conflict_degree)
        
        print(f"空间分解完成: 主要区域 {len(self.primary_indices)} 个, "
              f"次要区域 {len(self.secondary_indices)} 个")
        
        # 构建软着色器
        if matrix_type == 'comprehensive':
            omega_mat = self.preprocessor.get_comprehensive_matrix()
        elif matrix_type == 'conflict':
            omega_mat = self.preprocessor.conflict_matrix
        elif matrix_type == 'confusion':
            omega_mat = self.preprocessor.confusion_matrix
        else:
            omega_mat = self.preprocessor.interference_matrix
        
        self.coloring = GraphSoftColoring(omega_mat, self.num_pci)
        return conflict_degree
    
    def generate_initial_solution(self):
        """基于分层编码与图软着色生成初始解"""
        # 第一层：生成执行次序
        primary_order = list(self.primary_indices)
        random.shuffle(primary_order)
        
        secondary_order = list(self.secondary_indices)
        random.shuffle(secondary_order)
        
        order = primary_order + secondary_order
        
        # 第二层：通过图软着色分配PCI
        pci = self.coloring.assign_pci(order)
        
        return order, pci
    
    def solution_transform(self, order, pci):
        """解变换策略：主要区域内部次序互换 + 次要区域内部次序互换"""
        new_order = order.copy()
        m = len(self.primary_indices)
        n_total = len(order)
        
        # 主要区域内随机选两个位置互换
        if m >= 2:
            i1, i2 = random.sample(range(m), 2)
            new_order[i1], new_order[i2] = new_order[i2], new_order[i1]
        
        # 次要区域内随机选两个位置互换
        if n_total - m >= 2:
            i1, i2 = random.sample(range(m, n_total), 2)
            new_order[i1], new_order[i2] = new_order[i2], new_order[i1]
        
        # 根据新次序重新着色
        new_pci = self.coloring.assign_pci(new_order)
        return new_order, new_pci
    
    def random_mutation(self, order, pci):
        """随机变异策略：主要区域与次要区域之间互换"""
        new_order = order.copy()
        m = len(self.primary_indices)
        n_total = len(order)
        
        if m > 0 and n_total - m > 0:
            i1 = random.randint(0, m - 1)
            i2 = random.randint(m, n_total - 1)
            new_order[i1], new_order[i2] = new_order[i2], new_order[i1]
        
        new_pci = self.coloring.assign_pci(new_order)
        return new_order, new_pci
    
    def perturbation(self, order, pci):
        """扰动策略：连续子区域次序循环移位"""
        new_order = order.copy()
        m = len(self.primary_indices)
        
        # 在主要区域中选一段连续区域循环移位
        if m >= 3:
            start = random.randint(0, m - 3)
            length = random.randint(2, min(5, m - start))
            segment = new_order[start:start + length]
            # 循环左移
            segment = segment[1:] + [segment[0]]
            new_order[start:start + length] = segment
        
        new_pci = self.coloring.assign_pci(new_order)
        return new_order, new_pci
    
    def update_neighborhood_prob(self):
        """自适应动态邻域结构选择"""
        w = self.omega_weight
        for k in range(2):
            ratio = self.s_k[k] / max(self.st_k[k], 1)
            self.p_k[k] = w * self.p_k[k] + (1 - w) * ratio
        
        total = sum(self.p_k)
        if total > 0:
            self.p_k = [p / total for p in self.p_k]
    
    def adaptive_temperature(self, T_max, mu, R_i, lam):
        """自适应温度更新: θ_i = θ_m - μ * ln(1 + R_i / λ)"""
        return T_max - mu * math.log(1 + R_i / lam)
    
    def optimize(self, eval_func=None):
        """
        主从伴随优化主循环
        eval_func: 目标函数，默认为综合MR
        """
        if eval_func is None:
            eval_func = self.obj_func.compute_comprehensive_mr
        
        # 生成初始解
        best_order, best_pci = self.generate_initial_solution()
        best_cost = eval_func(best_pci)
        
        current_order, current_pci = best_order.copy(), best_pci.copy()
        current_cost = best_cost
        
        print(f"初始解综合MR: {best_cost}")
        
        T = self.T0
        mu = 50  # 惯性系数
        lam = 10  # 温度调节系数
        no_improve_count = 0  # R_i
        perturbation_count = 0
        
        history = [best_cost]
        
        for iteration in range(self.max_iter):
            if T < self.T_min:
                break
            if perturbation_count >= self.con_threshold:
                print(f"达到扰动终止条件，迭代 {iteration} 次")
                break
            
            # 自适应选择邻域结构
            self.update_neighborhood_prob()
            xi = random.random()
            
            if xi < self.p_k[0]:
                # 解变换策略
                new_order, new_pci = self.solution_transform(current_order, current_pci)
                k_selected = 0
            else:
                # 随机变异策略
                new_order, new_pci = self.random_mutation(current_order, current_pci)
                k_selected = 1
            
            self.st_k[k_selected] += 1
            new_cost = eval_func(new_pci)
            delta_f = new_cost - current_cost
            
            # Metropolis准则
            if delta_f < 0:
                current_order, current_pci = new_order, new_pci
                current_cost = new_cost
                self.s_k[k_selected] += 1
                
                if current_cost < best_cost:
                    best_order, best_pci = current_order.copy(), current_pci.copy()
                    best_cost = current_cost
                    no_improve_count = 0
                else:
                    no_improve_count += 1
            else:
                if T > 0 and random.random() < math.exp(-delta_f / max(T, 1e-10)):
                    current_order, current_pci = new_order, new_pci
                    current_cost = new_cost
                no_improve_count += 1
            
            # 扰动策略
            if no_improve_count >= self.cum_threshold:
                per_order, per_pci = self.perturbation(best_order, best_pci)
                per_cost = eval_func(per_pci)
                
                if per_cost < best_cost:
                    best_order, best_pci = per_order, per_pci
                    best_cost = per_cost
                    current_order, current_pci = per_order, per_pci
                    current_cost = per_cost
                
                no_improve_count = 0
                perturbation_count += 1
            
            # 自适应温度更新
            T = max(self.adaptive_temperature(self.T0, mu, no_improve_count, lam), self.T_min)
            T *= self.alpha
            
            history.append(best_cost)
            
            if iteration % 10 == 0:
                print(f"迭代 {iteration}: 当前最优MR = {best_cost}, 温度 = {T:.2f}")
        
        return best_pci, best_cost, history

# ============================================================
# 第六部分：禁忌主从伴随优化算法（问题三/四）
# ============================================================

class TabuMasterSlaveOptimizer(MasterSlaveOptimizer):
    """
    基于空间分解与禁忌主从伴随优化的PCI综合分配
    在主从伴随优化基础上增加禁忌表
    """
    
    def __init__(self, preprocessor, objective_func, num_pci=1008,
                 T0=1000, T_min=1, alpha=0.95, max_iter=500,
                 cum_threshold=20, con_threshold=5, omega=0.8,
                 tabu_size=50):
        super().__init__(preprocessor, objective_func, num_pci,
                         T0, T_min, alpha, max_iter,
                         cum_threshold, con_threshold, omega)
        self.tabu_size = tabu_size
        self.tabu_list = []
    
    def _solution_hash(self, pci):
        """计算解的哈希值用于禁忌表"""
        return hash(tuple(pci.tolist()))
    
    def is_tabu(self, pci):
        """检查解是否在禁忌表中"""
        h = self._solution_hash(pci)
        return h in self.tabu_list
    
    def add_to_tabu(self, pci):
        """将解加入禁忌表"""
        h = self._solution_hash(pci)
        self.tabu_list.append(h)
        if len(self.tabu_list) > self.tabu_size:
            self.tabu_list.pop(0)
    
    def optimize(self, eval_func=None):
        """带禁忌搜索的主从伴随优化"""
        if eval_func is None:
            eval_func = self.obj_func.compute_comprehensive_mr
        
        best_order, best_pci = self.generate_initial_solution()
        best_cost = eval_func(best_pci)
        
        current_order, current_pci = best_order.copy(), best_pci.copy()
        current_cost = best_cost
        self.add_to_tabu(best_pci)
        
        print(f"初始解MR: {best_cost}")
        
        T = self.T0
        mu = 50
        lam = 10
        no_improve_count = 0
        perturbation_count = 0
        history = [best_cost]
        
        for iteration in range(self.max_iter):
            if T < self.T_min or perturbation_count >= self.con_threshold:
                break
            
            self.update_neighborhood_prob()
            xi = random.random()
            
            if xi < self.p_k[0]:
                new_order, new_pci = self.solution_transform(current_order, current_pci)
                k_selected = 0
            else:
                new_order, new_pci = self.random_mutation(current_order, current_pci)
                k_selected = 1
            
            self.st_k[k_selected] += 1
            
            # 禁忌检查
            if self.is_tabu(new_pci):
                no_improve_count += 1
                T = max(self.adaptive_temperature(self.T0, mu, no_improve_count, lam), self.T_min)
                T *= self.alpha
                history.append(best_cost)
                continue
            
            new_cost = eval_func(new_pci)
            delta_f = new_cost - current_cost
            
            if delta_f < 0:
                current_order, current_pci = new_order, new_pci
                current_cost = new_cost
                self.s_k[k_selected] += 1
                self.add_to_tabu(new_pci)
                
                if current_cost < best_cost:
                    best_order, best_pci = current_order.copy(), current_pci.copy()
                    best_cost = current_cost
                    no_improve_count = 0
                else:
                    no_improve_count += 1
            else:
                if T > 0 and random.random() < math.exp(-delta_f / max(T, 1e-10)):
                    current_order, current_pci = new_order, new_pci
                    current_cost = new_cost
                    self.add_to_tabu(new_pci)
                no_improve_count += 1
            
            if no_improve_count >= self.cum_threshold:
                per_order, per_pci = self.perturbation(best_order, best_pci)
                per_cost = eval_func(per_pci)
                if per_cost < best_cost:
                    best_order, best_pci = per_order, per_pci
                    best_cost = per_cost
                    current_order, current_pci = per_order, per_pci
                    current_cost = per_cost
                no_improve_count = 0
                perturbation_count += 1
            
            T = max(self.adaptive_temperature(self.T0, mu, no_improve_count, lam), self.T_min)
            T *= self.alpha
            history.append(best_cost)
            
            if iteration % 10 == 0:
                print(f"迭代 {iteration}: 最优MR = {best_cost}, 温度 = {T:.2f}")
        
        return best_pci, best_cost, history

