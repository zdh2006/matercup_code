# 第四部分：目标函数计算
# ============================================================

class ObjectiveFunction:
    """目标函数计算"""
    
    def __init__(self, conflict_matrix, confusion_matrix, interference_matrix):
        self.A = conflict_matrix  # 冲突矩阵
        self.B = confusion_matrix  # 混淆矩阵
        self.C = interference_matrix  # 干扰矩阵
        self.n = conflict_matrix.shape[0]
    
    def compute_conflict_mr(self, pci):
        """计算冲突MR"""
        total = 0.0
        A = self.A
        rows, cols = A.nonzero()
        for idx in range(len(rows)):
            i, j = rows[idx], cols[idx]
            if pci[i] == pci[j]:
                total += A[i, j]
        return total
    
    def compute_confusion_mr(self, pci):
        """计算混淆MR"""
        total = 0.0
        B = self.B
        rows, cols = B.nonzero()
        for idx in range(len(rows)):
            i, j = rows[idx], cols[idx]
            if pci[i] == pci[j]:
                total += B[i, j]
        return total
    
    def compute_interference_mr(self, pci):
        """计算模3干扰MR"""
        total = 0.0
        C = self.C
        rows, cols = C.nonzero()
        for idx in range(len(rows)):
            i, j = rows[idx], cols[idx]
            if pci[i] % 3 == pci[j] % 3:
                total += C[i, j]
        return total
    
    def compute_comprehensive_mr(self, pci):
        """综合MR = 冲突 + 混淆 + 模3干扰"""
        return (self.compute_conflict_mr(pci) + 
                self.compute_confusion_mr(pci) + 
                self.compute_interference_mr(pci))
    
    def compute_comprehensive_mr_fast(self, pci):
        """快速计算综合MR（向量化）"""
        n = self.n
        conflict_total = 0.0
        confusion_total = 0.0
        interference_total = 0.0
        
        # 冲突矩阵
        rows, cols = self.A.nonzero()
        for idx in range(len(rows)):
            i, j = rows[idx], cols[idx]
            if pci[i] == pci[j]:
                conflict_total += self.A[i, j]
        
        # 混淆矩阵
        rows, cols = self.B.nonzero()
        for idx in range(len(rows)):
            i, j = rows[idx], cols[idx]
            if pci[i] == pci[j]:
                confusion_total += self.B[i, j]
        
        # 干扰矩阵
        rows, cols = self.C.nonzero()
        for idx in range(len(rows)):
            i, j = rows[idx], cols[idx]
            if pci[i] % 3 == pci[j] % 3:
                interference_total += self.C[i, j]
        
        return conflict_total + confusion_total + interference_total

