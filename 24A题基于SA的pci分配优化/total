# 第三部分：图软着色算法
# ============================================================

class GraphSoftColoring:
    """图软着色：为每个小区分配使冲突度最小的PCI"""
    
    def __init__(self, omega_matrix, num_pci=1008):
        """
        omega_matrix: 稀疏矩阵，记录小区间冲突度
        num_pci: 可用PCI数量
        """
        self.omega = omega_matrix
        self.num_pci = num_pci
        self.n = omega_matrix.shape[0]
    
    def assign_pci(self, order, existing_pci=None, mod3_matrix=None):
        """
        按照给定顺序分配PCI
        order: 分配顺序（小区索引列表）
        existing_pci: 已有PCI分配（用于约束）
        mod3_matrix: 干扰矩阵（用于模3优化）
        返回: PCI分配数组
        """
        pci_assignment = np.full(self.n, -1, dtype=int)
        
        if existing_pci is not None:
            pci_assignment = existing_pci.copy()
        
        for cell_idx in order:
            if pci_assignment[cell_idx] >= 0 and existing_pci is not None:
                continue
            
            # 计算每个PCI值的冲突代价
            costs = np.zeros(self.num_pci)
            
            # 获取当前小区的邻居
            row = self.omega.getrow(cell_idx)
            col = self.omega.getcol(cell_idx)
            
            neighbors_row = row.nonzero()[1]
            neighbors_col = col.nonzero()[0]
            
            # 对已分配PCI的邻居，计算冲突代价
            for j in neighbors_row:
                if pci_assignment[j] >= 0:
                    pci_j = pci_assignment[j]
                    # 相同PCI的冲突代价
                    costs[pci_j] += row[0, j]
                    # 模3干扰代价
                    if mod3_matrix is not None:
                        mod3_val = mod3_matrix[cell_idx, j]
                        for p in range(self.num_pci):
                            if p % 3 == pci_j % 3 and p != pci_j:
                                costs[p] += mod3_val
            
            for i_idx in neighbors_col:
                if pci_assignment[i_idx] >= 0:
                    pci_i = pci_assignment[i_idx]
                    costs[pci_i] += col[i_idx, 0]
                    if mod3_matrix is not None:
                        mod3_val = mod3_matrix[i_idx, cell_idx]
                        for p in range(self.num_pci):
                            if p % 3 == pci_i % 3 and p != pci_i:
                                costs[p] += mod3_val
            
            # 选择代价最小的PCI
            min_cost = np.min(costs)
            best_pcis = np.where(costs == min_cost)[0]
            pci_assignment[cell_idx] = np.random.choice(best_pcis)
        
        return pci_assignment

