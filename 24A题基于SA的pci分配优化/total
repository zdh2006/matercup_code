# 第一部分：数据预处理与冲突度统计
# ============================================================

class DataPreprocessor:
    """数据预处理：读取冲突、混淆、干扰矩阵，构建稀疏矩阵"""
    
    def __init__(self, num_cells=2067, num_pci=1008):
        self.num_cells = num_cells
        self.num_pci = num_pci  # PCI取值 0~1007
        self.conflict_matrix = None  # 冲突矩阵 A
        self.confusion_matrix = None  # 混淆矩阵 B
        self.interference_matrix = None  # 干扰矩阵 C
        self.cell_ids = []  # 小区ID列表
        self.cell_id_to_idx = {}  # 小区ID到索引的映射
    
    def load_data(self, conflict_file, confusion_file, interference_file, cell_list_file=None):
        """
        加载数据文件
        conflict_file: 冲突及干扰矩阵数据 (小区, 邻小区, 冲突MR, 干扰MR)
        confusion_file: 混淆矩阵数据 (小区, 邻小区, 混淆MR)
        cell_list_file: 优化小区列表
        """
        # 读取优化小区列表
        if cell_list_file:
            cell_df = pd.read_csv(cell_list_file)
            #通过pandas读文件并把返回值赋给cell_df，cell_df是一个DataFrame对象
            self.cell_ids = cell_df.iloc[:, 0].tolist()
            #把DataFrame对象的第一列（iloc[:, 0]）转换成列表（tolist()），是因为后续需要使用这个列表来构建小区ID到索引的映射
        else:
            self.cell_ids = list(range(self.num_cells))
            #如果没有提供小区列表文件，就默认使用0到num_cells-1的整数作为小区ID列表，因为题目中提到小区数量为2067，所以默认小区ID就是0到2066的整数列表
        
        self.cell_id_to_idx = {cid: idx for idx, cid in enumerate(self.cell_ids)}
        #给id到索引的映射，通过enumerate函数遍历cell_ids列表，获取每个小区ID（cid）和对应的索引（idx），然后构建一个字典（cell_id_to_idx）来存储这个映射关系，方便后续根据小区ID快速找到对应的索引位置
        n = len(self.cell_ids)
        #n是小区数量，通过计算cell_ids列表的长度来获取，因为后续需要构建n x n的矩阵，所以需要知道小区的数量
        self.num_cells = n
        #更新num_cells属性为实际的小区数量，以确保后续矩阵构建和索引映射的正确性
                
        # 初始化稀疏矩阵数据
        #使用defaultdict函数的原因是，避免键不存在的KeyError，方便后续矩阵补零
        conflict_data = defaultdict(float)#使用defaultdict来存储冲突数据，键是小区对(i, j)，值是对应的冲突MR，默认值为0.0
        confusion_data = defaultdict(float)
        interference_data = defaultdict(float)
        
        # 读取冲突及干扰数据
        cf_df = pd.read_csv(conflict_file)
        for _, row in cf_df.iterrows():
            cell_i = row.iloc[0]#
            cell_j = row.iloc[1]
            if cell_i in self.cell_id_to_idx and cell_j in self.cell_id_to_idx:
                i = self.cell_id_to_idx[cell_i]
                j = self.cell_id_to_idx[cell_j]
                conflict_data[(i, j)] = row.iloc[2]  # 冲突MR
                interference_data[(i, j)] = row.iloc[3]  # 干扰MR
        
        # 读取混淆数据
        cn_df = pd.read_csv(confusion_file)
        for _, row in cn_df.iterrows():
            cell_i = row.iloc[0]
            cell_j = row.iloc[1]
            if cell_i in self.cell_id_to_idx and cell_j in self.cell_id_to_idx:
                i = self.cell_id_to_idx[cell_i]
                j = self.cell_id_to_idx[cell_j]
                confusion_data[(i, j)] = row.iloc[2]
        
        # 补全：混淆矩阵有但冲突矩阵没有的
        for (i, j), v in confusion_data.items():
            if (i, j) not in conflict_data:
                conflict_data[(i, j)] = 0
                interference_data[(i, j)] = 0
        
        for (i, j), v in conflict_data.items():
            if (i, j) not in confusion_data:
                confusion_data[(i, j)] = 0
        
        # 构建稀疏矩阵
        rows_c, cols_c, vals_c = [], [], []
        rows_n, cols_n, vals_n = [], [], []
        rows_i, cols_i, vals_i = [], [], []
        
        for (i, j), v in conflict_data.items():
            rows_c.append(i); cols_c.append(j); vals_c.append(v)
        for (i, j), v in confusion_data.items():
            rows_n.append(i); cols_n.append(j); vals_n.append(v)
        for (i, j), v in interference_data.items():
            rows_i.append(i); cols_i.append(j); vals_i.append(v)
        
        self.conflict_matrix = csr_matrix((vals_c, (rows_c, cols_c)), shape=(n, n))
        self.confusion_matrix = csr_matrix((vals_n, (rows_n, cols_n)), shape=(n, n))
        self.interference_matrix = csr_matrix((vals_i, (rows_i, cols_i)), shape=(n, n))
    
    def load_data_from_arrays(self, A, B, C):
        """直接从numpy数组加载（用于测试）"""
        n = A.shape[0]
        self.num_cells = n
        self.cell_ids = list(range(n))
        self.cell_id_to_idx = {i: i for i in range(n)}
        self.conflict_matrix = csr_matrix(A)
        self.confusion_matrix = csr_matrix(B)
        self.interference_matrix = csr_matrix(C)
    
    def get_comprehensive_matrix(self):
        """综合MR矩阵 = 冲突 + 混淆 + 干扰"""
        return self.conflict_matrix + self.confusion_matrix + self.interference_matrix
    
    def compute_region_conflict_degree(self, matrix_type='comprehensive'):
        """
        计算每个区域的冲突度
        matrix_type: 'comprehensive', 'conflict', 'confusion', 'interference'
        """
        if matrix_type == 'comprehensive':
            M = self.get_comprehensive_matrix()
        elif matrix_type == 'conflict':
            M = self.conflict_matrix
        elif matrix_type == 'confusion':
            M = self.confusion_matrix
        elif matrix_type == 'interference':
            M = self.interference_matrix
        else:
            M = self.get_comprehensive_matrix()
        
        # 区域冲突度 = 该区域与所有邻域MR之和（行和+列和）
        row_sum = np.array(M.sum(axis=1)).flatten()
        col_sum = np.array(M.sum(axis=0)).flatten()
        conflict_degree = row_sum + col_sum
        return conflict_degree

# ============================================================
# 第二部分：空间分解（对数差分法）
# ============================================================

class SpaceDecomposer:
    """基于对数差分的空间分解"""
    
    def __init__(self, threshold=0.5):
        self.threshold = threshold
        self.primary_indices = []
        self.secondary_indices = []
    
    def decompose(self, conflict_degree):
        """
        将区域分为主要区域和次要区域
        conflict_degree: 每个区域的冲突度数组
        """
        n = len(conflict_degree)
        
        # 按冲突度降序排列
        sorted_indices = np.argsort(-conflict_degree)
        sorted_values = conflict_degree[sorted_indices]
        
        # 过滤零值
        nonzero_mask = sorted_values > 0
        if np.sum(nonzero_mask) < 2:
            self.primary_indices = sorted_indices.tolist()
            self.secondary_indices = []
            return self.primary_indices, self.secondary_indices
        
        # 对数变换
        log_values = np.log1p(sorted_values[nonzero_mask])
        
        # 一阶差分
        diff_values = np.diff(log_values)
        
        # 找到差分绝对值超过阈值的第一个位置
        split_idx = len(log_values)  # 默认全部为主要区域
        for i in range(len(diff_values)):
            if abs(diff_values[i]) > self.threshold:
                split_idx = i + 1
                break
        
        # 确保至少有一定比例的主要区域
        min_primary = max(10, int(0.1 * n))
        split_idx = max(split_idx, min_primary)
        split_idx = min(split_idx, n)
        
        nonzero_sorted = sorted_indices[nonzero_mask]
        zero_sorted = sorted_indices[~nonzero_mask]
        
        self.primary_indices = nonzero_sorted[:split_idx].tolist()
        self.secondary_indices = nonzero_sorted[split_idx:].tolist() + zero_sorted.tolist()
        
        return self.primary_indices, self.secondary_indices

