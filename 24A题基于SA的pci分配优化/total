def plot_results(history, title="收敛曲线"):
    """绘制收敛曲线"""
    try:
        import matplotlib.pyplot as plt
        plt.figure(figsize=(10, 6))
        plt.plot(history, 'b-', linewidth=1.5)
        plt.xlabel('迭代次数')
        plt.ylabel('综合MR')
        plt.title(title)
        plt.grid(True, alpha=0.3)
        plt.tight_layout()
        plt.savefig(f'{title}.png', dpi=150)
        plt.show()
    except ImportError:
        print("matplotlib未安装，跳过绘图")

