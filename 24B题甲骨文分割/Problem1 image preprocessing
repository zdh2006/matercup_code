    save_directory = "results/problem1_preprocessing"
    
    for img_path in image_paths:
        if os.path.exists(img_path):
            result = preprocess_oracle_bone_image(img_path, save_dir=save_directory)
        else:
            print(f"文件不存在: {img_path}")
            print("请将甲骨文图像放入正确的路径中")
    
    print("\n" + "=" * 60)
    print("问题一：图像预处理模型完成！")
    print("处理步骤：Otsu二值化 → 闭运算 → 开运算 → 高斯滤波 → 中值滤波")
    print("=" * 60)