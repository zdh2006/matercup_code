def plot_training_curves(epochs, train_rmse, train_loss, val_rmse, val_loss, save_dir=None):
    """
    绘制YOLOv5训练过程的RMSE和Loss曲线（对应论文图18、图19）
    """
    fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(12, 8))
    
    # 图18: RMSE曲线
    ax1.plot(epochs, train_rmse, 'b-o', markersize=3, label='Training RMSE', alpha=0.7)
    ax1.plot(epochs, val_rmse, 'r--s', markersize=3, label='Validation RMSE', alpha=0.7)
    ax1.set_xlabel('Epoch (迭代)')
    ax1.set_ylabel('RMSE')
    ax1.set_title('图18: YOLOv5训练过程RMSE曲线图')
    ax1.legend()
    ax1.grid(True, alpha=0.3)
    
    # 图19: Loss曲线
    ax2.plot(epochs, train_loss, 'b-o', markersize=3, label='Training Loss', alpha=0.7)
    ax2.plot(epochs, val_loss, 'r--s', markersize=3, label='Validation Loss', alpha=0.7)
    ax2.set_xlabel('Epoch (迭代)')
    ax2.set_ylabel('Loss (损失)')
    ax2.set_title('图19: YOLOv5训练过程LOSS曲线图')
    ax2.legend()
    ax2.grid(True, alpha=0.3)
    
    plt.tight_layout()
    
    if save_dir:
        os.makedirs(save_dir, exist_ok=True)
        plt.savefig(os.path.join(save_dir, 'yolov5_training_curves.png'), dpi=150)
    
    plt.show()
    plt.close()


