def calculate_iou(box1, box2):
    """
    5.2.1 计算交并比 IoU = (A ∩ B) / (A ∪ B)
    
    参数:
        box1, box2: [x_min, y_min, x_max, y_max]
    返回:
        IoU值 (0~1之间)
    """
    x1 = max(box1[0], box2[0])
    y1 = max(box1[1], box2[1])
    x2 = min(box1[2], box2[2])
    y2 = min(box1[3], box2[3])
    
    intersection = max(0, x2 - x1) * max(0, y2 - y1)
    
    area1 = (box1[2] - box1[0]) * (box1[3] - box1[1])
    area2 = (box2[2] - box2[0]) * (box2[3] - box2[1])
    union = area1 + area2 - intersection
    
    iou = intersection / union if union > 0 else 0
    return iou


def calculate_precision(tp, fp):
    """
    5.2.2 查准率 P = TP / (TP + FP)
    """
    return tp / (tp + fp) if (tp + fp) > 0 else 0


def calculate_recall(tp, fn):
    """
    5.2.3 查全率 R = TP / (TP + FN)
    """
    return tp / (tp + fn) if (tp + fn) > 0 else 0


def calculate_ap(precisions, recalls):
    """
    5.2.4 平均准确率 AP = ∫₀¹ P(R)dR
    使用11点插值法计算AP
    """
    # 11点插值
    ap = 0.0
    for t in np.arange(0, 1.1, 0.1):
        p_interp = 0
        for p, r in zip(precisions, recalls):
            if r >= t:
                p_interp = max(p_interp, p)
        ap += p_interp
    ap /= 11.0
    return ap


def calculate_map(ap_list):
    """
    5.2.5 平均准确率均值 mAP = Σ(APm) / m
    """
    return np.mean(ap_list) if len(ap_list) > 0 else 0


def evaluate_detection(predictions, ground_truths, iou_threshold=0.5):
    """
    完整的目标检测评估流程
    """
    tp, fp, fn = 0, 0, 0
    
    for pred_boxes, gt_boxes in zip(predictions, ground_truths):
        matched = [False] * len(gt_boxes)
        
        for pred_box in pred_boxes:
            best_iou = 0
            best_gt_idx = -1
            
            for gt_idx, gt_box in enumerate(gt_boxes):
                iou = calculate_iou(pred_box, gt_box)
                if iou > best_iou:
                    best_iou = iou
                    best_gt_idx = gt_idx
            
            if best_iou >= iou_threshold and not matched[best_gt_idx]:
                tp += 1
                matched[best_gt_idx] = True
            else:
                fp += 1
        
        fn += sum(1 for m in matched if not m)
    
    precision = calculate_precision(tp, fp)
    recall = calculate_recall(tp, fn)
    f1 = 2 * precision * recall / (precision + recall) if (precision + recall) > 0 else 0
    
    print(f"\n模型评估结果:")
    print(f"  TP: {tp}, FP: {fp}, FN: {fn}")
    print(f"  Precision (查准率): {precision:.4f}")
    print(f"  Recall (查全率): {recall:.4f}")
    print(f"  F1 Score: {f1:.4f}")
    
    return precision, recall, f1


