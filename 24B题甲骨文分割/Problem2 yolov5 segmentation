def convert_label_to_yolo(annotation_path, image_width, image_height, output_path):
    """
    将标注文件转换为YOLOv5格式
    YOLOv5标注格式：class_id x_center y_center width height (归一化)
    
    参数:
        annotation_path: 原始标注文件路径（JSON格式）
        image_width: 图像宽度
        image_height: 图像高度
        output_path: 输出的YOLO格式标注文件路径
    """
    with open(annotation_path, 'r', encoding='utf-8') as f:
        annotations = json.load(f)
    
    yolo_labels = []
    
    for ann in annotations.get('annotations', []):
        # 获取边界框坐标 [x_min, y_min, width, height]
        bbox = ann.get('bbox', [])
        if len(bbox) != 4:
            continue
        
        x_min, y_min, w, h = bbox
        
        # 转换为YOLO格式（归一化到[0,1]）
        x_center = (x_min + w / 2) / image_width
        y_center = (y_min + h / 2) / image_height
        norm_w = w / image_width
        norm_h = h / image_height
        
        # class_id = 0（甲骨文字只有一个类别）
        class_id = 0
        
        yolo_labels.append(f"{class_id} {x_center:.6f} {y_center:.6f} {norm_w:.6f} {norm_h:.6f}")
    
    # 写入YOLO格式标注文件
    with open(output_path, 'w') as f:
        f.write('\n'.join(yolo_labels))
    
    return len(yolo_labels)


def prepare_yolo_dataset(image_dir, label_dir, output_dir, train_ratio=0.8):
    """
    准备YOLOv5训练数据集
    将数据分为训练集和验证集，按照YOLOv5的目录结构组织
    
    目录结构:
    output_dir/
    ├── images/
    │   ├── train/
    │   └── val/
    └── labels/
        ├── train/
        └── val/
    """
    # 创建目录结构
    for split in ['train', 'val']:
        os.makedirs(os.path.join(output_dir, 'images', split), exist_ok=True)
        os.makedirs(os.path.join(output_dir, 'labels', split), exist_ok=True)
    
    # 获取所有图像文件
    image_files = [f for f in os.listdir(image_dir) 
                   if f.lower().endswith(('.jpg', '.jpeg', '.png', '.bmp'))]
    
    # 随机打乱并划分
    random.shuffle(image_files)
    split_idx = int(len(image_files) * train_ratio)
    train_files = image_files[:split_idx]
    val_files = image_files[split_idx:]
    
    print(f"总图像数: {len(image_files)}")
    print(f"训练集: {len(train_files)} 张")
    print(f"验证集: {len(val_files)} 张")
    
    # 复制文件到对应目录
    for split, files in [('train', train_files), ('val', val_files)]:
        for img_file in files:
            # 复制图像
            src_img = os.path.join(image_dir, img_file)
            dst_img = os.path.join(output_dir, 'images', split, img_file)
            shutil.copy2(src_img, dst_img)
            
            # 复制标签
            label_file = os.path.splitext(img_file)[0] + '.txt'
            src_label = os.path.join(label_dir, label_file)
            dst_label = os.path.join(output_dir, 'labels', split, label_file)
            if os.path.exists(src_label):
                shutil.copy2(src_label, dst_label)
    
    return train_files, val_files


def create_yolo_config(output_dir, num_classes=1, class_names=None):
    """
    创建YOLOv5数据集配置文件 data.yaml
    """
    if class_names is None:
        class_names = ['oracle_character']
    
    config_content = f"""# YOLOv5 甲骨文数据集配置
path: {os.path.abspath(output_dir)}
train: images/train
val: images/val

# 类别
nc: {num_classes}
names: {class_names}
"""
    
    config_path = os.path.join(output_dir, 'data.yaml')
    with open(config_path, 'w') as f:
        f.write(config_content)
    
    print(f"YOLOv5配置文件已创建: {config_path}")
    return config_path


