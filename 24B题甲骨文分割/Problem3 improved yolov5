"""
===================================================================
问题三：自动单字分割模型的改进（改进的YOLOv5）
===================================================================
功能：对YOLOv5进行一系列改进，提升甲骨文图像分割的准确性
改进内容：
  1. PP-LC主干网络 —— 轻量化，减少参数和计算量
  2. SE注意力机制  —— 增强关键区域的显著性
  3. GSPPF模块    —— 用GeLU替代SiLU，提升多尺度特征捕捉
  4. CA注意力机制  —— 增强特征通道的识别和加权
  5. Focal CIoU损失函数 —— 解决正负样本不平衡问题
  6. 消融实验      —— 验证各模块的有效性
===================================================================
"""

import torch
import torch.nn as nn
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
import os


# ================================================================
# 6.1.1 PP-LC 主干网络（轻量化卷积网络）
# ================================================================

class DepthwiseSeparableConv(nn.Module):
    """
    深度可分离卷积（PP-LC网络的核心组件）
    将标准卷积分解为：深度卷积(DW) + 逐点卷积(PW)
    参数量降低为原来的 1/N + 1/D²_K
    """
    def __init__(self, in_channels, out_channels, kernel_size=3, stride=1, padding=1):
        super().__init__()
        # 深度卷积 (Depthwise): 每个通道独立卷积
        self.depthwise = nn.Conv2d(
            in_channels, in_channels, kernel_size=kernel_size,
            stride=stride, padding=padding, groups=in_channels, bias=False
        )
        self.bn1 = nn.BatchNorm2d(in_channels)
        
        # 逐点卷积 (Pointwise): 1×1卷积进行通道融合
        self.pointwise = nn.Conv2d(
            in_channels, out_channels, kernel_size=1, bias=False
        )
        self.bn2 = nn.BatchNorm2d(out_channels)
        self.act = nn.Hardswish(inplace=True)  # PP-LC使用HSwish激活
    
    def forward(self, x):
        x = self.act(self.bn1(self.depthwise(x)))
        x = self.act(self.bn2(self.pointwise(x)))
        return x


class SEAttention(nn.Module):
    """
    6.1 SE注意力机制 (Squeeze-and-Excitation)
    通过自适应调整特征图的权重，加强关键区域的显著性
    
    结构: GAvgPool → FC → ReLU → FC → Sigmoid → Scale
    """
    def __init__(self, channels, reduction=16):
        super().__init__()
        self.avg_pool = nn.AdaptiveAvgPool2d(1)  # GAP: 全局平均池化
        self.fc = nn.Sequential(
            nn.Linear(channels, channels // reduction, bias=False),  # FC降维
            nn.ReLU(inplace=True),                                    # ReLU激活
            nn.Linear(channels // reduction, channels, bias=False),   # FC升维
            nn.Sigmoid()                                              # Sigmoid生成权重
        )
    
    def forward(self, x):
        b, c, _, _ = x.size()
        # Squeeze: 全局平均池化
        y = self.avg_pool(x).view(b, c)
        # Excitation: FC + ReLU + FC + Sigmoid
        y = self.fc(y).view(b, c, 1, 1)
        # Scale: 通道加权
        return x * y.expand_as(x)


class PPLCBackbone(nn.Module):
    """
    PP-LC主干网络
    轻量化设计：Conv2D → DepthSepConv(3×3) × 3 → DepthSepConv(5×5)
    可选的SE注意力机制
    """
    def __init__(self, in_channels=3, base_channels=32):
        super().__init__()
        
        # 320×320 → Conv2D
        self.stem = nn.Sequential(
            nn.Conv2d(in_channels, base_channels, kernel_size=3, stride=2, padding=1, bias=False),
            nn.BatchNorm2d(base_channels),
            nn.Hardswish(inplace=True)
        )
        
        # 160×160 → 3×3 DepthSepConv
        self.stage1 = DepthwiseSeparableConv(base_channels, base_channels * 2, 3, stride=2, padding=1)
        
        # 80×80 → 3×3 DepthSepConv + SE
        self.stage2 = nn.Sequential(
            DepthwiseSeparableConv(base_channels * 2, base_channels * 4, 3, stride=2, padding=1),
            SEAttention(base_channels * 4)
        )
        
        # 40×40 → 3×3 DepthSepConv
        self.stage3 = DepthwiseSeparableConv(base_channels * 4, base_channels * 8, 3, stride=2, padding=1)
        
        # 20×20 → 5×5 DepthSepConv
        self.stage4 = DepthwiseSeparableConv(base_channels * 8, base_channels * 16, 5, stride=2, padding=2)
    
    def forward(self, x):
        features = []
        x = self.stem(x)
        x = self.stage1(x)
        features.append(x)       # P2
        x = self.stage2(x)
        features.append(x)       # P3
        x = self.stage3(x)
        features.append(x)       # P4
        x = self.stage4(x)
        features.append(x)       # P5
        return features


# ================================================================
# 6.2 空间金字塔池化 GSPPF（使用GeLU激活函数）
# ================================================================

class ConvBNGeLU(nn.Module):
    """卷积 + BatchNorm + GeLU 模块"""
    def __init__(self, in_channels, out_channels, kernel_size=1, stride=1, padding=0):
        super().__init__()
        self.conv = nn.Conv2d(in_channels, out_channels, kernel_size, stride, padding, bias=False)
        self.bn = nn.BatchNorm2d(out_channels)
        self.act = nn.GELU()  # 使用GeLU替代SiLU
    
    def forward(self, x):
        return self.act(self.bn(self.conv(x)))


class GSPPF(nn.Module):
    """
    改进的空间金字塔池化模块 GSPPF
    
    使用GeLU激活函数替代SiLU:
    - SiLU: f(x) = x · σ(x) = x / (1 + e^(-x))
    - GeLU: f(x) = x · Φ(x)  其中Φ(x)是标准正态分布的CDF
    
    GeLU提供更平滑的梯度，便于模型训练期间的收敛
    
    结构: ConvBNGeLU → 3×MaxPool2d(k5,s1,p2)串联 → Concat → ConvBNGeLU
    """
    def __init__(self, in_channels, out_channels, kernel_size=5):
        super().__init__()
        hidden_channels = in_channels // 2
        
        self.conv1 = ConvBNGeLU(in_channels, hidden_channels, 1, 1, 0)
        self.conv2 = ConvBNGeLU(hidden_channels * 4, out_channels, 1, 1, 0)
        
        # 三个串联的MaxPool2d
        self.maxpool = nn.MaxPool2d(
            kernel_size=kernel_size, stride=1, padding=kernel_size // 2
        )
    
    def forward(self, x):
        x = self.conv1(x)
        y1 = self.maxpool(x)
        y2 = self.maxpool(y1)
        y3 = self.maxpool(y2)
        # Concat: 拼接原始特征和三次池化后的特征
        return self.conv2(torch.cat([x, y1, y2, y3], dim=1))


# ================================================================
# 6.3.1 CA注意力机制 (Coordinate Attention)
# ================================================================

class CoordinateAttention(nn.Module):
    """
    CA注意力机制
    通过引入坐标信息，能够更好地捕获长程依赖性
    
    结构:
    1. X Avg Pool + Y Avg Pool (沿不同方向的平均池化)
    2. Concat + Conv2d
    3. BatchNorm + Non-linear
    4. Split → Conv2d + Sigmoid (分别对H和W方向)
    5. 相乘得到注意力权重
    """
    def __init__(self, channels, reduction=32):
        super().__init__()
        self.pool_h = nn.AdaptiveAvgPool2d((None, 1))  # X方向平均池化
        self.pool_w = nn.AdaptiveAvgPool2d((1, None))  # Y方向平均池化
        
        mid_channels = max(8, channels // reduction)
        
        self.conv1 = nn.Conv2d(channels, mid_channels, kernel_size=1, bias=False)
        self.bn1 = nn.BatchNorm2d(mid_channels)
        self.act = nn.Hardswish(inplace=True)
        
        self.conv_h = nn.Conv2d(mid_channels, channels, kernel_size=1, bias=False)
        self.conv_w = nn.Conv2d(mid_channels, channels, kernel_size=1, bias=False)
    
    def forward(self, x):
        b, c, h, w = x.size()
        
        # 1. 沿H和W方向分别做平均池化
        x_h = self.pool_h(x)            # (B, C, H, 1)
        x_w = self.pool_w(x).permute(0, 1, 3, 2)  # (B, C, W, 1) → (B, C, 1, W) → permute
        
        # 2. Concat + Conv + BN + Act
        y = torch.cat([x_h, x_w], dim=2)  # (B, C, H+W, 1)
        y = self.act(self.bn1(self.conv1(y)))
        
        # 3. Split
        x_h, x_w = torch.split(y, [h, w], dim=2)
        x_w = x_w.permute(0, 1, 3, 2)
        
        # 4. 分别通过Conv + Sigmoid得到注意力权重
        a_h = torch.sigmoid(self.conv_h(x_h))
        a_w = torch.sigmoid(self.conv_w(x_w))
        
        # 5. 相乘
        return x * a_h * a_w


# ================================================================
# 6.3.2 Focal CIoU 损失函数
# ================================================================

def ciou_loss(pred_boxes, target_boxes):
    """
    CIoU损失函数
    L_CIoU = 1 - IoU + ρ²(b, b^gt)/c² + αv
    
    其中:
    - ρ²(b, b^gt): 预测框和真实框中心点的欧式距离
    - c: 最小外接矩形的对角线长度
    - α: 权重参数
    - v: 宽高比的一致性度量
    """
    # 计算IoU
    x1 = torch.max(pred_boxes[:, 0], target_boxes[:, 0])
    y1 = torch.max(pred_boxes[:, 1], target_boxes[:, 1])
    x2 = torch.min(pred_boxes[:, 2], target_boxes[:, 2])
    y2 = torch.min(pred_boxes[:, 3], target_boxes[:, 3])
    
    intersection = torch.clamp(x2 - x1, min=0) * torch.clamp(y2 - y1, min=0)
    
    area_pred = (pred_boxes[:, 2] - pred_boxes[:, 0]) * (pred_boxes[:, 3] - pred_boxes[:, 1])
    area_target = (target_boxes[:, 2] - target_boxes[:, 0]) * (target_boxes[:, 3] - target_boxes[:, 1])
    
    union = area_pred + area_target - intersection
    iou = intersection / (union + 1e-7)
    
    # 中心点距离
    pred_cx = (pred_boxes[:, 0] + pred_boxes[:, 2]) / 2
    pred_cy = (pred_boxes[:, 1] + pred_boxes[:, 3]) / 2
    target_cx = (target_boxes[:, 0] + target_boxes[:, 2]) / 2
    target_cy = (target_boxes[:, 1] + target_boxes[:, 3]) / 2
    
    rho2 = (pred_cx - target_cx) ** 2 + (pred_cy - target_cy) ** 2
    
    # 最小外接矩形对角线
    enclose_x1 = torch.min(pred_boxes[:, 0], target_boxes[:, 0])
    enclose_y1 = torch.min(pred_boxes[:, 1], target_boxes[:, 1])
    enclose_x2 = torch.max(pred_boxes[:, 2], target_boxes[:, 2])
    enclose_y2 = torch.max(pred_boxes[:, 3], target_boxes[:, 3])
    c2 = (enclose_x2 - enclose_x1) ** 2 + (enclose_y2 - enclose_y1) ** 2
    
    # 宽高比一致性
    pred_w = pred_boxes[:, 2] - pred_boxes[:, 0]
    pred_h = pred_boxes[:, 3] - pred_boxes[:, 1]
    target_w = target_boxes[:, 2] - target_boxes[:, 0]
    target_h = target_boxes[:, 3] - target_boxes[:, 1]
    
    v = (4 / (np.pi ** 2)) * (torch.atan(target_w / (target_h + 1e-7)) - 
                                torch.atan(pred_w / (pred_h + 1e-7))) ** 2
    
    alpha = v / (1 - iou + v + 1e-7)
    
    # CIoU Loss
    loss = 1 - iou + rho2 / (c2 + 1e-7) + alpha * v
    
    return loss


def focal_ciou_loss(pred_boxes, target_boxes, gamma=1.5):
    """
    6.3.2 Focal CIoU损失函数
    L_FocalCIoU = (1 - IoU + ρ²(b,b^gt)/c² + αv)^γ
    
    γ (gamma) = 1.5: 调节因子，使模型更加注重难以分类的正样本
    解决正负样本不平衡问题
    """
    loss = ciou_loss(pred_boxes, target_boxes)
    
    # Focal权重: 对loss取γ次方
    focal_loss = loss ** gamma
    
    return focal_loss.mean()


# ================================================================
# 6.3.3 改进后的完整网络架构
# ================================================================

class ImprovedYOLOv5(nn.Module):
    """
    改进后的YOLOv5网络 (YOLOv5s-Light)
    
    主干网络: PP-LC (轻量化)
    特征增强: GSPPF (GeLU空间金字塔池化)
    颈部网络: 带CA注意力机制的PAN结构
    损失函数: Focal CIoU
    """
    def __init__(self, num_classes=1, in_channels=3):
        super().__init__()
        
        # 主干网络: PP-LC
        self.backbone = PPLCBackbone(in_channels=in_channels, base_channels=32)
        
        # GSPPF模块
        self.gsppf = GSPPF(512, 512)
        
        # 颈部网络 (简化的PAN + CA注意力)
        self.upsample = nn.Upsample(scale_factor=2, mode='nearest')
        
        # CA注意力机制
        self.ca_attention1 = CoordinateAttention(256)
        self.ca_attention2 = CoordinateAttention(512)
        
        # 检测头
        self.detect_head = nn.Conv2d(256, num_classes * 5, kernel_size=1)
        
        self.num_classes = num_classes
    
    def forward(self, x):
        # 主干网络特征提取
        features = self.backbone(x)
        
        # GSPPF
        p5 = self.gsppf(features[-1])
        
        # CA注意力增强
        p4 = self.ca_attention1(features[-2])
        
        # 简化的检测输出
        output = self.detect_head(p4)
        
        return output


