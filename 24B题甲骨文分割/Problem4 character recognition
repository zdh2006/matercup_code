def build_cnn_model(input_shape=(224, 224, 3), num_classes=76):
    """
    7.1 建立CNN文字识别模型
    
    结构:
    - 7.1.1 输入层: 图像 → 二维矩阵，归一化到[0,1]
    - 7.1.2 卷积层: Conv2D(32, 3×3, relu) → Conv2D(64, 3×3, relu)
    - 7.1.3 池化层: MaxPooling2D(2×2) × 2
    - 7.1.4 全连接层: Flatten → Dense(128, relu) → Dense(num_classes, softmax)
    
    优化器: SGD
    损失函数: 交叉熵
    """
    if not HAS_TF:
        print("[模拟] CNN模型结构:")
        print("  Input(224×224×3) → Rescaling(1/255)")
        print("  → Conv2D(32, 3×3, relu) → MaxPool2D(2×2)")
        print("  → Conv2D(64, 3×3, relu) → MaxPool2D(2×2)")
        print("  → Flatten → Dense(128, relu) → Dense(num_classes, softmax)")
        return None
    
    model = models.Sequential([
        # 7.1.1 输入层: 归一化处理，将0-255映射到0-1
        layers.InputLayer(input_shape=input_shape),
        layers.Rescaling(1.0 / 255),
        
        # 7.1.2 第一次卷积: 32个3×3卷积核 + ReLU激活
        # ReLU: f(x) = max(0, x)
        layers.Conv2D(32, (3, 3), activation='relu', padding='same'),
        
        # 7.1.3 第一次池化: 2×2最大池化
        # kernel_size=2, stride=2, padding=0
        layers.MaxPooling2D((2, 2)),
        
        # 7.1.2 第二次卷积: 64个3×3卷积核 + ReLU激活
        layers.Conv2D(64, (3, 3), activation='relu', padding='same'),
        
        # 7.1.3 第二次池化
        layers.MaxPooling2D((2, 2)),
        
        # 7.1.4 全连接层
        layers.Flatten(),                           # 展平为一维向量
        layers.Dense(128, activation='relu'),        # 128个全连接节点
        layers.Dense(num_classes, activation='softmax')  # softmax输出概率
    ])
    
    # 7.2 模型训练配置
    # SGD优化器: θ_{t+1} = θ_t - α_t * ∇f_{i_t}(θ_t)
    model.compile(
        optimizer=optimizers.SGD(learning_rate=0.01, momentum=0.9),
        loss='sparse_categorical_crossentropy',
        metrics=['accuracy']
    )
    
    model.summary()
    return model


# ================================================================
# Part 2: MobileNetV2模型 (第八章)
# ================================================================

def build_mobilenetv2_model(input_shape=(224, 224, 3), num_classes=76):
    """
    8.1 建立MobileNetV2文字识别模型
    
    核心技术:
    - 8.1.1 深度可分离卷积: 参数量降低 1/N + 1/D²_K ≈ 1/9 (当D_K=3)
    - 8.1.2 MobileNetV2特性:
        * Linear bottlenecks: 部分ReLU替换为线性激活
        * Inverted residual blocks: 先升维后降维（倒残差结构）
    - 8.1.3 Adam优化器:
        * m_t = β1*m_{t-1} + (1-β1)*g_t  (一阶矩估计)
        * u_t = β2*u_{t-1} + (1-β2)*g²_t (二阶矩估计)
        * θ_{t+1} = θ_t - α/(√û_t + ε) * m̂_t
        * β1=0.9, β2=0.999
    
    结构:
    - 输入层 → Rescaling → MobileNetV2(预训练) → GlobalAveragePooling2D → Dense(softmax)
    """
    if not HAS_TF:
        print("[模拟] MobileNetV2模型结构:")
        print("  Input(224×224×3) → Rescaling(1/255)")
        print("  → MobileNetV2(预训练, include_top=False)")
        print("  → GlobalAveragePooling2D")
        print("  → Dense(num_classes, softmax)")
        print("  优化器: Adam (β1=0.9, β2=0.999)")
        return None
    
    # 使用预训练的MobileNetV2作为主干网络
    base_model = MobileNetV2(
        input_shape=input_shape,
        include_top=False,          # 不包含原始的分类头
        weights='imagenet'          # 使用ImageNet预训练权重
    )
    
    # 冻结预训练层（可选：微调时解冻部分层）
    base_model.trainable = False
    
    model = models.Sequential([
        layers.InputLayer(input_shape=input_shape),
        layers.Rescaling(1.0 / 255),             # 归一化
        base_model,                                # MobileNetV2主干
        layers.GlobalAveragePooling2D(),           # 全局平均池化
        layers.Dense(num_classes, activation='softmax')  # 分类层
    ])
    
    # 8.1.3 Adam优化器
    # |Δθ_{t,k}| <≈ α (参数变化量近似受全局学习率限制)
    model.compile(
        optimizer=optimizers.Adam(learning_rate=0.001),  # Adam优化器
        loss='sparse_categorical_crossentropy',
        metrics=['accuracy']
    )
    
    model.summary()
    return model


