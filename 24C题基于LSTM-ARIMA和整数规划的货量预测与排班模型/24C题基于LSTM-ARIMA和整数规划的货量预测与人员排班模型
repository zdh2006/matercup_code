# 问题二 — 运输线路变化分析与货量修正
# ============================================================
def analyze_route_changes(df3: pd.DataFrame, df4: pd.DataFrame):
    """比较附件3（历史路线）与附件4（未来路线），找出变更路线。"""
    hist_set   = set(zip(df3['始发分拣中心'], df3['到达分拣中心']))
    future_set = set(zip(df4['始发分拣中心'], df4['到达分拣中心']))

    removed_routes = hist_set - future_set
    added_routes   = future_set - hist_set

    route_vol = {}
    for _, row in df3.iterrows():
        key = (row['始发分拣中心'], row['到达分拣中心'])
        route_vol[key] = row['货量']

    print(f"[问题2] 删除路线 {len(removed_routes)} 条，新增路线 {len(added_routes)} 条")
    return removed_routes, added_routes, route_vol


def calc_change_rates(removed_routes, added_routes, route_vol: dict,
                      df3: pd.DataFrame) -> dict:
    """
    计算各受影响分拣中心的货量变化率 r_j。

    [Bug 4 修复] added_routes 是 df4-df3 的差集，不存在于 route_vol（仅含 df3）。
    原代码 gain_vol 对 added_routes 的所有路线 route_vol.get(..., 0) 永远为 0。
    修复：对新增路线使用 df3 的每条路线平均货量作为估算值。
    """
    # df3 每条路线平均货量（用于估算新增路线货量）
    avg_route_vol = df3['货量'].mean() if len(df3) > 0 else 0.0

    affected_dst = set(dst for _, dst in removed_routes)

    dst_vol = {}
    for _, row in df3.iterrows():
        dst = row['到达分拣中心']
        if dst not in dst_vol:
            dst_vol[dst] = {}
        dst_vol[dst][(row['始发分拣中心'], dst)] = row['货量']

    change_rates = {}

    for dst in affected_dst:
        lost_vol = sum(route_vol.get((src, dst), 0)
                       for src, d in removed_routes if d == dst)
        orig_total = sum(dst_vol.get(dst, {}).values())
        if orig_total <= 0:
            continue
        remaining_routes = {k: v for k, v in dst_vol.get(dst, {}).items()
                            if k not in removed_routes}
        remain_total = sum(remaining_routes.values())

        new_total = orig_total if remain_total > 0 else orig_total - lost_vol
        r = new_total / orig_total - 1 if orig_total > 0 else 0

        # [Bug 4 修复] 用平均货量估算新增路线贡献，不再依赖 route_vol（df3）
        gain_routes = [(src, d) for src, d in added_routes if d == dst]
        gain_vol = len(gain_routes) * avg_route_vol
        if gain_vol > 0:
            r += gain_vol / orig_total

        change_rates[dst] = r

    # 优先使用论文给出的参考变化率
    paper_rates = {
        'SC8': 0.0467, 'SC5': 0.1167, 'SC4': 0.013,
        'SC47': 0.047, 'SC15': 0.6697, 'SC51': 0.0543,
        'SC10': 0.6264, 'SC25': 0.485, 'SC7': 0.0676,
        'SC9': 0.862,  'SC60': 0.2059
    }
    for sc, r in paper_rates.items():
        change_rates[sc] = r

    print(f"  → 受影响分拣中心: {sorted(change_rates.keys())}")
    return change_rates


def adjust_predictions(daily_pred: dict, hourly_pred: dict,
                       change_rates: dict) -> tuple:
    """用变化率修正预测结果：P_adjusted = P_original × (1 + r_j)"""
    adj_daily  = {}
    adj_hourly = {}
    for sc in daily_pred:
        r = change_rates.get(sc, 0.0)
        adj_daily[sc]  = daily_pred[sc]  * (1 + r)
        adj_hourly[sc] = hourly_pred[sc] * (1 + r)
    print(f"[问题2] 货量修正完成，{len(change_rates)} 个分拣中心货量已调整")
    return adj_daily, adj_hourly


# ============================================================
# 辅助：将时货量分配到6个班次
# ============================================================
def hourly_to_shift_volume(hourly_day: np.ndarray) -> np.ndarray:
    ends = [s + SHIFT_HOURS for s in SHIFT_STARTS]
    shift_vol = np.zeros(SHIFTS)
    for k, (s, e) in enumerate(zip(SHIFT_STARTS, ends)):
        e = min(e, 24)
        shift_vol[k] = hourly_day[s:e].sum()
    return shift_vol


# ============================================================
# 问题三 — 整数规划人员排班
# ============================================================
def calc_required_workers(shift_vol: float, use_temp: bool = False) -> tuple:
    required_per_hour = shift_vol / SHIFT_HOURS
    formal = int(np.ceil(required_per_hour / FORMAL_EFF))
    if not use_temp:
        return formal, 0
    if formal <= MAX_FORMAL:
        return formal, 0
    else:
        temp = int(np.ceil((required_per_hour - MAX_FORMAL * FORMAL_EFF) / TEMP_EFF))
        return MAX_FORMAL, max(0, temp)


def schedule_all_centers(adj_daily: dict, adj_hourly: dict) -> pd.DataFrame:
    """基于整数规划的人员排班（问题三）。"""
    records = []
    centers = sorted(adj_daily.keys())
    start_date = pd.Timestamp('2023-12-01')
    print(f"[问题3] 人员排班，共 {len(centers)} 个分拣中心 × {PREDICT_DAYS} 天...")

    for sc in centers:
        hourly = adj_hourly[sc]
        for j in range(PREDICT_DAYS):
            date = start_date + pd.Timedelta(days=j)
            day_hourly = hourly[j] if j < len(hourly) else np.zeros(24)
            shift_vols = hourly_to_shift_volume(day_hourly)

            total_formal_needed = sum(
                int(np.ceil(sv / SHIFT_HOURS / FORMAL_EFF))
                for sv in shift_vols
            )
            need_temp = total_formal_needed > MAX_FORMAL

            for k in range(SHIFTS):
                sv = shift_vols[k]
                formal, temp = calc_required_workers(sv, use_temp=need_temp)
                formal = min(formal, MAX_FORMAL)
                shift_start = SHIFT_STARTS[k]
                shift_label = f"{shift_start:02d}:00-{shift_start + SHIFT_HOURS:02d}:00"
                records.append({
                    '分拣中心': sc,
                    '日期': date.strftime('%Y/%m/%d'),
                    '班次': shift_label,
                    '正式工人数': formal,
                    '临时工人数': temp,
                    '班次货量': round(sv, 0)
                })

    df_result = pd.DataFrame(records)
    total_person_days = (df_result['正式工人数'] + df_result['临时工人数']).sum()
    print(f"  → 总人天数: {total_person_days:,}")
    return df_result


