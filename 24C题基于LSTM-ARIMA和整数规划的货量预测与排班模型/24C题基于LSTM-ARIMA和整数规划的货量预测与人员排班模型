# 问题四 — SC60 多目标遗传算法排班
# ============================================================
class GeneticScheduler:
    """基于遗传算法的多目标排班优化（问题四）。"""

    def __init__(self, n_formal=MAX_FORMAL_SC60, n_days=PREDICT_DAYS,
                 n_shifts=SHIFTS, pop_size=50, generations=100,
                 mutation_rate=0.02, cx_rate=0.8):
        self.n_formal      = n_formal
        self.n_days        = n_days
        self.n_shifts      = n_shifts
        self.pop_size      = pop_size
        self.generations   = generations
        self.mutation_rate = mutation_rate
        self.cx_rate       = cx_rate

    def _encode(self):
        pop = np.zeros((self.pop_size, self.n_formal, self.n_days), dtype=np.int8)
        max_days = int(self.n_days * MAX_ATT_RATE)
        for ind in range(self.pop_size):
            for i in range(self.n_formal):
                att_days = np.random.randint(int(max_days * 0.5), max_days + 1)
                days_on  = np.random.choice(self.n_days, att_days, replace=False)
                for d in days_on:
                    pop[ind, i, d] = np.random.randint(1, self.n_shifts + 1)
        return pop

    def _fix_consecutive(self, schedule_i: np.ndarray) -> np.ndarray:
        consec = 0
        for d in range(self.n_days):
            if schedule_i[d] > 0:
                consec += 1
                if consec > MAX_CONSEC:
                    schedule_i[d] = 0
                    consec = 0
            else:
                consec = 0
        return schedule_i

    def _fix_attendance_rate(self, schedule_i: np.ndarray) -> np.ndarray:
        max_d   = int(self.n_days * MAX_ATT_RATE)
        on_days = np.where(schedule_i > 0)[0]
        if len(on_days) > max_d:
            turn_off = np.random.choice(on_days, len(on_days) - max_d, replace=False)
            schedule_i[turn_off] = 0
        return schedule_i

    def _repair(self, ind: np.ndarray) -> np.ndarray:
        for i in range(self.n_formal):
            ind[i] = self._fix_attendance_rate(ind[i])
            ind[i] = self._fix_consecutive(ind[i])
        return ind

    def _fitness(self, ind: np.ndarray, shift_vols: np.ndarray) -> float:
        daily_formal = np.zeros((self.n_days, self.n_shifts), dtype=int)
        for i in range(self.n_formal):
            for d in range(self.n_days):
                k = ind[i, d] - 1
                if 0 <= k < self.n_shifts:
                    daily_formal[d, k] += 1
        total_days = int((ind > 0).sum())
        att_rates  = (ind > 0).sum(axis=1) / self.n_days
        rate_var   = att_rates.var()
        penalty    = 0.0
        for d in range(self.n_days):
            for k in range(self.n_shifts):
                capacity = daily_formal[d, k] * FORMAL_EFF * SHIFT_HOURS
                gap      = max(0, shift_vols[d, k] - capacity)
                penalty += gap / max(shift_vols[d, k], 1)
        return total_days + 500 * rate_var + 200 * penalty

    def _crossover(self, p1, p2):
        if np.random.rand() > self.cx_rate:
            return p1.copy(), p2.copy()
        point = np.random.randint(1, self.n_formal)
        c1 = np.vstack([p1[:point], p2[point:]])
        c2 = np.vstack([p2[:point], p1[point:]])
        return c1, c2

    def _mutate(self, ind: np.ndarray) -> np.ndarray:
        for i in range(self.n_formal):
            for d in range(self.n_days):
                if np.random.rand() < self.mutation_rate:
                    if ind[i, d] > 0:
                        ind[i, d] = 0
                    else:
                        ind[i, d] = np.random.randint(1, self.n_shifts + 1)
        return ind

    def optimize(self, shift_vols: np.ndarray) -> np.ndarray:
        pop        = self._encode()
        best_ind   = None
        best_score = np.inf
        print(f"  → 遗传算法迭代 {self.generations} 代...")

        for gen in range(self.generations):
            for idx in range(self.pop_size):
                pop[idx] = self._repair(pop[idx])
            scores   = np.array([self._fitness(pop[idx], shift_vols)
                                  for idx in range(self.pop_size)])
            best_idx = int(scores.argmin())
            if scores[best_idx] < best_score:
                best_score = scores[best_idx]
                best_ind   = pop[best_idx].copy()
            if gen % 20 == 0:
                print(f"    代 {gen:3d} | 最优适应度: {best_score:.1f}")
            inv_scores   = 1 / (scores + 1e-9)
            probs        = inv_scores / inv_scores.sum()
            selected_idx = np.random.choice(self.pop_size, self.pop_size,
                                             p=probs, replace=True)
            selected = [pop[i].copy() for i in selected_idx]
            new_pop  = []
            for i in range(0, self.pop_size - 1, 2):
                c1, c2 = self._crossover(selected[i], selected[i + 1])
                new_pop.extend([self._mutate(c1), self._mutate(c2)])
            if len(new_pop) < self.pop_size:
                new_pop.append(selected[-1])
            pop = np.array(new_pop[:self.pop_size])

        print(f"    最终最优适应度: {best_score:.1f}")
        return best_ind


def schedule_sc60(adj_daily: dict, adj_hourly: dict):
    """SC60 分拣中心多目标遗传算法排班（问题四）。"""
    sc = 'SC60'
    hourly = adj_hourly.get(sc, np.zeros((PREDICT_DAYS, 24)))
    if sc not in adj_daily:
        print(f"[问题4] 警告: {sc} 不在预测结果中，使用零值")
        hourly = np.zeros((PREDICT_DAYS, 24))

    shift_vols = np.zeros((PREDICT_DAYS, SHIFTS))
    for j in range(PREDICT_DAYS):
        day_h = hourly[j] if j < len(hourly) else np.zeros(24)
        shift_vols[j] = hourly_to_shift_volume(day_h)

    print(f"[问题4] SC60 遗传算法排班...")
    ga = GeneticScheduler(n_formal=MAX_FORMAL_SC60, n_days=PREDICT_DAYS,
                          n_shifts=SHIFTS, pop_size=30, generations=60,
                          mutation_rate=0.015)
    best = ga.optimize(shift_vols)

    start_date = pd.Timestamp('2023-12-01')
    records    = []
    for i in range(MAX_FORMAL_SC60):
        for j in range(PREDICT_DAYS):
            k = int(best[i, j]) - 1
            if 0 <= k < SHIFTS:
                date = start_date + pd.Timedelta(days=j)
                shift_start = SHIFT_STARTS[k]
                shift_label = f"{shift_start:02d}:00-{shift_start + SHIFT_HOURS:02d}:00"
                records.append({
                    '分拣中心': sc,
                    '日期': date.strftime('%Y/%m/%d'),
                    '班次': shift_label,
                    '出勤正式工编号': i + 1,
                    '类型': '正式工'
                })

    daily_formal_cnt = np.zeros((PREDICT_DAYS, SHIFTS), dtype=int)
    for i in range(MAX_FORMAL_SC60):
        for j in range(PREDICT_DAYS):
            k = int(best[i, j]) - 1
            if 0 <= k < SHIFTS:
                daily_formal_cnt[j, k] += 1

    temp_records = []
    for j in range(PREDICT_DAYS):
        date = start_date + pd.Timedelta(days=j)
        for k in range(SHIFTS):
            formal_cap  = daily_formal_cnt[j, k] * FORMAL_EFF * SHIFT_HOURS
            gap         = max(0, shift_vols[j, k] - formal_cap)
            temp_needed = int(np.ceil(gap / (TEMP_EFF * SHIFT_HOURS)))
            shift_start = SHIFT_STARTS[k]
            shift_label = f"{shift_start:02d}:00-{shift_start + SHIFT_HOURS:02d}:00"
            temp_records.append({
                '分拣中心': sc,
                '日期': date.strftime('%Y/%m/%d'),
                '班次': shift_label,
                '临时工人数': temp_needed
            })

    df_formal = pd.DataFrame(records)
    df_temp   = pd.DataFrame(temp_records)
    att_rates = (best > 0).sum(axis=1) / PREDICT_DAYS
    print(f"  → 正式工平均出勤率: {att_rates.mean():.3f}")
    print(f"  → 正式工出勤率方差: {att_rates.var():.6f}")
    print(f"  → 需临时工总计: {df_temp['临时工人数'].sum()}")
    return df_formal, df_temp


