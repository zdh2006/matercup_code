    df4 = pd.read_csv(f"{DATA_DIR}/附件4.csv", encoding='gbk')

    # ── [Bug 3 修复] 指定日期格式，避免 pandas 版本差异导致 MM/DD 误判 ──
    df1['日期'] = pd.to_datetime(df1['日期'], format='%Y/%m/%d')
    df2['日期'] = pd.to_datetime(df2['日期'], format='%Y/%m/%d')

