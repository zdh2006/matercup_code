def load_data():
    """加载四个附件数据"""
    df1 = pd.read_csv(f"{DATA_DIR}/附件1.csv", encoding='gbk')
    df2 = pd.read_csv(f"{DATA_DIR}/附件2.csv", encoding='gbk')
